# ================================
# Environment Configuration Example
# ================================
# Copy this file to .env and fill in your actual values

# ====================
# Application
# ====================
APP_ENV=dev
DEBUG=true
APP_NAME=AI Interviewer API
API_VERSION=1.0.0
BASE_URL=http://localhost:8000

# ====================
# Database (PostgreSQL)
# ====================
DATABASE_URL=postgresql+asyncpg://user:password@host:port/database
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false
DB_POOL_PRE_PING=true
DB_QUERY_TIMEOUT=30

# ====================
# Redis
# ====================
REDIS_URL=redis://:password@host:port/0
REDIS_DB=0
REDIS_SESSION_TTL=3600
REDIS_PASSWORD=your-redis-password

# ====================
# Qdrant (Vector Database)
# ====================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=interview_questions
QDRANT_EMBEDDING_DIM=768  # Matches all-mpnet-base-v2 dimensions

# ====================
# LLM Provider
# ====================
# Options: openai, anthropic, groq
DEFAULT_LLM_PROVIDER=groq

# API Keys (set based on your provider)
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Self-hosted Embedding Service
EMBEDDING_MODEL_URL=http://localhost:8080

# Model routing
LLM_MODEL_QUESTION_GENERATION=gpt-oss-120b
LLM_MODEL_EVALUATION=gpt-oss-120b
LLM_MODEL_RESUME_PARSING=gpt-oss-120b
LLM_MODEL_REPORT_GENERATION=gpt-oss-120b

# Model parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TIMEOUT_SECONDS=30

# ====================
# Sandbox Execution
# ====================
SANDBOX_IMAGE_CPP=code-sandbox-cpp:latest
SANDBOX_IMAGE_JAVA=code-sandbox-java:latest
SANDBOX_IMAGE_PYTHON=code-sandbox-python:latest

SANDBOX_TIME_LIMIT_MS=2000
SANDBOX_MEMORY_LIMIT_KB=262144
SANDBOX_PROCESS_LIMIT=1
SANDBOX_MAX_OUTPUT_SIZE=1048576

SANDBOX_NETWORK_DISABLED=true
SANDBOX_SECCOMP_PROFILE=

# ====================
# Security & JWT
# ====================
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=your-secret-key-min-32-chars-long-change-in-production
JWT_PUBLIC_KEY_PATH=
JWT_PRIVATE_KEY_PATH=

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

PASSWORD_HASH_ALGORITHM=bcrypt
PASSWORD_HASH_ROUNDS=12

ENABLE_SECURE_HEADERS=true
ALLOWED_HOSTS=["localhost","127.0.0.1","https://orange-desert-0625bb200.7.azurestaticapps.net"]

# ====================
# Audio Processing
# ====================
SILENCE_THRESHOLD_MS=3000
SILENCE_CONFIDENCE_THRESHOLD=0.8

AUDIO_TRANSCRIPTION_PROVIDER=whisper
AUDIO_CONFIDENCE_THRESHOLD=0.7
MAX_TRANSCRIPT_LENGTH=10000

ENABLE_AUDIO_ANALYSIS=true
AUDIO_CHUNK_SIZE_MS=500

# ====================
# Rate Limiting
# ====================
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_SECONDS=900

API_RATE_LIMIT=100
API_RATE_WINDOW_SECONDS=60

MAX_CONCURRENT_INTERVIEWS_PER_CANDIDATE=1
MAX_CODE_SUBMISSIONS_PER_MINUTE=5

# ====================
# Feature Flags
# ====================
ENABLE_AI_EVALUATION=true
ENABLE_PROCTORING=true
ENABLE_AUDIO_ANALYSIS=true
ENABLE_CODE_EXECUTION=true

ENABLE_PRACTICE_MODE=false
ENABLE_HUMAN_OVERRIDE=true
ENABLE_RESUME_PARSING=true
ENABLE_MOCK_DATA=false

# ====================
# Azure Blob Storage
# ====================
# Uncomment and set these to enable Azure Blob Storage
# AZURE_STORAGE_ACCOUNT_NAME=your_account_name
# AZURE_STORAGE_ACCOUNT_KEY=your_account_key
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_CONTAINER_RESUMES=candidate-resumes
# AZURE_CONTAINER_RECORDINGS=interview-recordings
# AZURE_CONTAINER_IMAGES=candidate-images
# AZURE_CONTAINER_LOGOS=organization-logos
# AZURE_CONTAINER_JOB_DESCRIPTIONS=job-descriptions
# AZURE_MAX_UPLOAD_SIZE_MB=50
# AZURE_SAS_TOKEN_EXPIRY_HOURS=1
