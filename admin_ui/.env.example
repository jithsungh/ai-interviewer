# API Configuration
VITE_API_BASE_URL=http://localhost:8000

# Proctoring WebRTC Live Monitoring
# WebSocket signaling endpoint for live WebRTC playback (optional)
# If not set, monitoring falls back to blob playback only
# VITE_PROCTORING_LIVE_SIGNALING_URL=ws://localhost:8000/api/v1/proctoring/signaling/watch/:submissionId

# Optional: STUN server for WebRTC connectivity
# VITE_PROCTORING_WEBRTC_STUN=stun:stun.l.google.com:19302
